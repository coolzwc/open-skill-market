---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLang, MESSAGES, type Lang } from "@/lib/i18n";
import { CDN_BASE_URL } from "@/lib/market-data";

export const prerender = true;

export async function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "zh" } }];
}

const lang = getLang(Astro.params.lang) as Lang;
const t = MESSAGES[lang];
const altLang = lang === "en" ? "zh" : "en";

const tools = [
  { key: "cursor",  label: t.tabCursor,  hint: t.installHintCursor,  flag: "--tool cursor" },
  { key: "claude",  label: t.tabClaude,  hint: t.installHintClaude,  flag: "--tool claude" },
  { key: "codex",   label: t.tabCodex,   hint: t.installHintCodex,   flag: "--tool codex" },
  { key: "copilot", label: t.tabCopilot, hint: t.installHintCopilot, flag: "--tool copilot" },
  { key: "openclaw", label: t.tabOpenclaw, hint: t.installHintOpenclaw, flag: "--tool openclaw" },
  { key: "gemini",   label: t.tabGemini,   hint: t.installHintGemini,   flag: "--tool gemini" }
];

const title = `${t.siteName} | ${t.backToMarket}`;
const description = t.siteDescription;
const canonicalPath = `/${lang}/skill/`;
const altPath = `/${altLang}/skill/`;
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  altPath={altPath}
  type="article"
>
  <script is:inline src="/skill-store.js"></script>
  <!-- Topbar -->
  <header class="topbar">
    <a class="brand" href={`/${lang}/`}>{t.siteName}</a>
    <div class="topbar-right">
      <a class="gh-link" href="https://github.com/coolzwc/open-skill-market" target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.694.825.576C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
      </a>
      <nav class="lang-switch" aria-label={t.language} id="lang-switch-nav">
        <a href="#" class="lang-link-en" data-lang="en">EN</a>
        <a href="#" class="lang-link-zh" data-lang="zh">中文</a>
      </nav>
      <div class="lang-dropdown" aria-label={t.language}>
        <button class="lang-dropdown-toggle" type="button">
          {lang === "en" ? "EN" : "中文"}
          <svg class="chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="lang-dropdown-menu">
          <a href="#" class="lang-dropdown-en" data-lang="en">
            <svg class="check-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            EN
          </a>
          <a href="#" class="lang-dropdown-zh" data-lang="zh">
            <svg class="check-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            中文
          </a>
        </div>
      </div>
    </div>
  </header>

  <main class="detail-page">
    <div class="detail-container">
      <a class="back-link animate-in" href={`/${lang}/`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        {t.backToMarket}
      </a>

      <div id="detail-loading" class="detail-loading animate-in">
        <div class="loading-spinner">{t.loading}</div>
      </div>

      <div id="detail-notfound" class="detail-notfound" style="display:none;">
        <p class="notfound-text">{lang === "zh" ? "未找到该技能。" : "Skill not found."}</p>
        <a href={`/${lang}/`} class="back-link">{t.backToMarket}</a>
      </div>

      <div id="detail-content" class="detail-content" style="display:none;">
        <div class="detail-grid">
          <div class="detail-main">
            <div class="detail-hero animate-in delay-1">
              <div class="hero-glow"></div>
              <div class="hero-content">
                <div class="hero-top-row">
                  <span class="card-category" id="detail-category" data-cat="Other">Other</span>
                  <span class="version-badge" id="detail-version" style="display:none;"></span>
                </div>
                <h1 class="detail-title" id="detail-title"></h1>
                <p class="detail-desc" id="detail-desc"></p>
                <div class="detail-stats" id="detail-stats"></div>
              </div>
            </div>

            <div class="detail-section detail-section-security animate-in delay-2" id="detail-security-wrap" style="display:none;">
              <h2 class="section-label">{t.securityTitle}</h2>
              <div class="security-panel" id="detail-security">
                <div class="security-row" id="detail-security-score-row" style="display:none;">
                  <span class="security-label" id="detail-security-score-label"></span>
                  <div class="security-score-bar"><div class="security-score-fill" id="detail-security-score-fill"></div></div>
                  <span class="security-score-value" id="detail-security-score-value"></span>
                </div>
                <div class="security-row" id="detail-security-risk-row" style="display:none;">
                  <span class="security-label" id="detail-security-risk-label"></span>
                  <span class="risk-badge" id="detail-security-risk-badge"></span>
                </div>
                <div class="security-row" id="detail-security-tags-row" style="display:none;">
                  <span class="security-label" id="detail-security-tags-label"></span>
                  <div class="security-tags" id="detail-security-tags"></div>
                </div>
                <div class="security-row" id="detail-security-time-row" style="display:none;">
                  <span class="security-label" id="detail-security-time-label"></span>
                  <span class="security-time" id="detail-security-time"></span>
                </div>
              </div>
            </div>

            <div class="detail-section animate-in delay-2" id="detail-agents-wrap" style="display:none;">
              <h2 class="section-label">{t.compatibility}</h2>
              <div class="agent-badges" id="detail-agents"></div>
            </div>

            <div class="detail-section animate-in delay-2">
              <h2 class="section-label">{t.quickInstall}</h2>
              <div class="install-panel">
                <div class="install-tabs" role="tablist">
                  {tools.map((tool, idx) => (
                    <button
                      class={`install-tab${idx === 0 ? " active" : ""}`}
                      role="tab"
                      data-tool={tool.key}
                      aria-selected={idx === 0 ? "true" : "false"}
                    >
                      {tool.label}
                    </button>
                  ))}
                </div>
                {tools.map((tool, idx) => (
                  <div
                    class="install-body"
                    data-panel={tool.key}
                    style={idx === 0 ? "" : "display:none;"}
                    role="tabpanel"
                  >
                    <div class="cmd-row">
                      <code class="install-cmd" data-tool={tool.key}></code>
                      <button class="copy-btn" data-cmd="" title={t.copyCommand}>
                        <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;"><polyline points="20 6 9 17 4 12"/></svg>
                      </button>
                    </div>
                    <div class="cmd-hint">{tool.hint}</div>
                  </div>
                ))}
              </div>
            </div>

            <div class="detail-section cli-quickstart animate-in delay-2">
              <div class="cli-qs-header">
                <div class="cli-qs-left">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                  <div>
                    <h3 class="cli-qs-title">{t.cliGetStarted}</h3>
                    <p class="cli-qs-desc">{t.cliGetStartedDesc}</p>
                  </div>
                </div>
                <a class="cli-qs-link" href={`/${lang}/guide/`}>
                  {t.viewFullGuide}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
              <div class="cli-qs-cmds">
                <div class="cli-qs-cmd">
                  <span class="cli-qs-label">{t.guideCmdSearch}</span>
                  <code>npx skill-market search &lt;keyword&gt;</code>
                </div>
                <div class="cli-qs-cmd">
                  <span class="cli-qs-label">{t.guideCmdList}</span>
                  <code>npx skill-market list --tool cursor</code>
                </div>
                <div class="cli-qs-cmd">
                  <span class="cli-qs-label">{t.guideCmdUpdate}</span>
                  <code>npx skill-market update --all --tool cursor</code>
                </div>
              </div>
            </div>

            <div class="detail-section animate-in delay-3" id="detail-tags-wrap" style="display:none;">
              <h2 class="section-label">{t.tags}</h2>
              <div class="tag-cloud" id="detail-tags"></div>
            </div>
          </div>

          <aside class="detail-aside animate-in delay-3">
            <div class="aside-card">
              <h3 class="aside-card-title">{t.sourceRepo}</h3>
              <a href="#" id="aside-repo-link" target="_blank" rel="noreferrer" class="aside-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.694.825.576C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
                <span id="aside-repo-label"></span>
                <svg class="ext-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
              <a href="#" id="aside-details-link" target="_blank" rel="noreferrer" class="aside-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                <span>SKILL.md</span>
                <svg class="ext-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
              <a href="#" id="aside-zip-link" target="_blank" rel="noreferrer" download class="aside-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                <span>{t.downloadZip}</span>
                <svg class="ext-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
            <div class="aside-card" id="aside-files-wrap" style="display:none;">
              <h3 class="aside-card-title">{t.files}</h3>
              <ul class="file-list" id="aside-files"></ul>
            </div>
            <div class="aside-card" id="aside-cats-wrap" style="display:none;">
              <h3 class="aside-card-title">{t.categoryLabel}</h3>
              <div class="aside-categories" id="aside-cats"></div>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} <a href="https://github.com/coolzwc/open-skill-market" target="_blank" rel="noreferrer">Open Skill Market</a>. MIT License.
    </footer>
  </main>
</BaseLayout>

<script
  define:vars={{ cdnBaseUrl: CDN_BASE_URL, lang, altLang, starsLabel: t.stars, copyTitle: t.copyCommand, securityTitle: t.securityTitle, securityScoreLabel: t.securityScoreLabel, riskLevelLabel: t.riskLevelLabel, scanTagsLabel: t.scanTagsLabel, scannedAtLabel: t.scannedAtLabel, securityNotScanned: t.securityNotScanned, riskLow: t.riskLow, riskMedium: t.riskMedium, riskHigh: t.riskHigh, riskCritical: t.riskCritical }}
  is:inline
>
(function () {
  var pathname = window.location.pathname;
  var match = pathname.match(/^\/(en|zh)\/skill\/(.+)$/);
  if (!match || !match[2]) {
    window.location.href = "/" + (lang || "en") + "/";
    return;
  }
  var currentLang = match[1];
  var skillId = match[2];

  var loadingEl = document.getElementById("detail-loading");
  var notfoundEl = document.getElementById("detail-notfound");
  var contentEl = document.getElementById("detail-content");

  function showLoading() {
    if (loadingEl) loadingEl.style.display = "";
    if (notfoundEl) notfoundEl.style.display = "none";
    if (contentEl) contentEl.style.display = "none";
  }
  function showNotFound() {
    if (loadingEl) loadingEl.style.display = "none";
    if (notfoundEl) notfoundEl.style.display = "block";
    if (contentEl) contentEl.style.display = "none";
  }
  function showContent() {
    if (loadingEl) loadingEl.style.display = "none";
    if (notfoundEl) notfoundEl.style.display = "none";
    if (contentEl) contentEl.style.display = "block";
  }

  function esc(str) {
    if (!str) return "";
    var span = document.createElement("span");
    span.textContent = str;
    return span.innerHTML;
  }

  var agentIcons = { cursor: "Cursor", "claude-code": "Claude Code", "codex-cli": "Codex CLI", "github-copilot": "Copilot" };

  function renderSkill(skill) {
    document.title = skill.name + " | Open Skill Market";
    var metaDesc = document.querySelector('meta[name="description"]');
    if (metaDesc) metaDesc.setAttribute("content", skill.description || "Open Skill Market");
    var canonical = document.querySelector('link[rel="canonical"]');
    if (canonical) canonical.setAttribute("href", "https://skillmarket.cc/" + currentLang + "/skill/" + skill.id);
    var altLink = document.querySelector('link[rel="alternate"][hreflang="' + (currentLang === "en" ? "zh" : "en") + '"]');
    if (altLink) altLink.setAttribute("href", "https://skillmarket.cc/" + (currentLang === "en" ? "zh" : "en") + "/skill/" + skill.id);

    var cat = (skill.categories && skill.categories[0]) || "Other";
    var catEl = document.getElementById("detail-category");
    if (catEl) { catEl.textContent = cat; catEl.setAttribute("data-cat", cat); }
    var verEl = document.getElementById("detail-version");
    if (verEl) {
      if (skill.version) { verEl.textContent = "v" + skill.version; verEl.style.display = ""; }
      else verEl.style.display = "none";
    }
    var titleEl = document.getElementById("detail-title");
    if (titleEl) titleEl.textContent = skill.name || "";
    var descEl = document.getElementById("detail-desc");
    if (descEl) descEl.textContent = skill.description || "";

    var statsHtml = '<a href="' + esc(skill.repoUrl) + '" target="_blank" rel="noreferrer" class="stat-chip author-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>@' + esc(skill.author || "unknown") + '</a>';
    statsHtml += '<span class="stat-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg> ' + (skill.stars || 0).toLocaleString() + ' ' + (starsLabel || "Stars") + '</span>';
    statsHtml += '<span class="stat-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 18V7l10 11V7"/></svg> ' + (skill.forks || 0).toLocaleString() + '</span>';
    if (skill.lastUpdated) {
      var dateStr = new Date(skill.lastUpdated).toLocaleDateString(currentLang === "zh" ? "zh-CN" : "en-US");
      statsHtml += '<span class="stat-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ' + esc(dateStr) + '</span>';
    }
    var statsEl = document.getElementById("detail-stats");
    if (statsEl) statsEl.innerHTML = statsHtml;

    var hasSecurity = skill.securityScore != null || (skill.scanTags && skill.scanTags.length) || skill.riskLevel || skill.scannedAt;
    var securityWrap = document.getElementById("detail-security-wrap");
    if (securityWrap) {
      if (hasSecurity) {
        securityWrap.style.display = "";
        var scoreRow = document.getElementById("detail-security-score-row");
        var scoreLabel = document.getElementById("detail-security-score-label");
        var scoreFill = document.getElementById("detail-security-score-fill");
        var scoreValue = document.getElementById("detail-security-score-value");
        if (scoreRow && scoreLabel && scoreFill && scoreValue) {
          if (skill.securityScore != null) {
            scoreRow.style.display = "";
            scoreLabel.textContent = (typeof securityScoreLabel !== "undefined" ? securityScoreLabel : "Security score") + ":";
            var pct = Math.min(100, Math.max(0, Number(skill.securityScore)));
            scoreFill.style.width = pct + "%";
            scoreFill.className = "security-score-fill risk-" + (skill.riskLevel || "unknown");
            scoreValue.textContent = pct + "/100";
          } else scoreRow.style.display = "none";
        }
        var riskRow = document.getElementById("detail-security-risk-row");
        var riskLabel = document.getElementById("detail-security-risk-label");
        var riskBadge = document.getElementById("detail-security-risk-badge");
        if (riskRow && riskLabel && riskBadge && skill.riskLevel) {
          riskRow.style.display = "";
          riskLabel.textContent = (typeof riskLevelLabel !== "undefined" ? riskLevelLabel : "Risk level") + ":";
          var riskText = skill.riskLevel;
          if (riskText === "low" && typeof riskLow !== "undefined") riskText = riskLow;
          else if (riskText === "medium" && typeof riskMedium !== "undefined") riskText = riskMedium;
          else if (riskText === "high" && typeof riskHigh !== "undefined") riskText = riskHigh;
          else if (riskText === "critical" && typeof riskCritical !== "undefined") riskText = riskCritical;
          riskBadge.textContent = riskText;
          riskBadge.className = "risk-badge risk-" + (skill.riskLevel || "");
        } else if (riskRow) riskRow.style.display = "none";
        var tagsRow = document.getElementById("detail-security-tags-row");
        var tagsLabel = document.getElementById("detail-security-tags-label");
        var tagsContainer = document.getElementById("detail-security-tags");
        if (tagsRow && tagsLabel && tagsContainer && skill.scanTags && skill.scanTags.length) {
          tagsRow.style.display = "";
          tagsLabel.textContent = (typeof scanTagsLabel !== "undefined" ? scanTagsLabel : "Scan tags") + ":";
          tagsContainer.innerHTML = skill.scanTags.map(function (tag) { return '<span class="security-tag">' + esc(tag) + '</span>'; }).join("");
        } else if (tagsRow) tagsRow.style.display = "none";
        var timeRow = document.getElementById("detail-security-time-row");
        var timeLabel = document.getElementById("detail-security-time-label");
        var timeEl = document.getElementById("detail-security-time");
        if (timeRow && timeLabel && timeEl && skill.scannedAt) {
          timeRow.style.display = "";
          timeLabel.textContent = (typeof scannedAtLabel !== "undefined" ? scannedAtLabel : "Last scanned") + ":";
          var scannedDate = new Date(skill.scannedAt);
          timeEl.textContent = !isNaN(scannedDate.getTime()) ? scannedDate.toLocaleDateString(currentLang === "zh" ? "zh-CN" : "en-US", { year: "numeric", month: "short", day: "numeric" }) : String(skill.scannedAt);
        } else if (timeRow) timeRow.style.display = "none";
      } else securityWrap.style.display = "none";
    }

    var agents = (skill.compatibility && skill.compatibility.agents) || [];
    var agentsWrap = document.getElementById("detail-agents-wrap");
    var agentsEl = document.getElementById("detail-agents");
    if (agentsWrap && agentsEl) {
      if (agents.length) {
        agentsWrap.style.display = "";
        agentsEl.innerHTML = agents.map(function (a) {
          var label = agentIcons[a] || a;
          return '<span class="agent-badge agent-' + esc(a) + '"><span class="agent-dot"></span>' + esc(label) + '</span>';
        }).join("");
      } else agentsWrap.style.display = "none";
    }

    var tools = [
      { key: "cursor", flag: "--tool cursor" },
      { key: "claude", flag: "--tool claude" },
      { key: "codex", flag: "--tool codex" },
      { key: "copilot", flag: "--tool copilot" }
    ];
    var cmdBase = "npx skill-market install " + (skill.name || "").replace(/"/g, '\\"');
    tools.forEach(function (tool) {
      var codeEl = document.querySelector('.install-cmd[data-tool="' + tool.key + '"]');
      var btn = codeEl && codeEl.closest(".cmd-row") && codeEl.closest(".cmd-row").querySelector(".copy-btn");
      var cmd = cmdBase + " " + tool.flag;
      if (codeEl) codeEl.textContent = cmd;
      if (btn) btn.dataset.cmd = cmd;
    });

    var tags = skill.tags || [];
    var tagsWrap = document.getElementById("detail-tags-wrap");
    var tagsEl = document.getElementById("detail-tags");
    if (tagsWrap && tagsEl) {
      if (tags.length) {
        tagsWrap.style.display = "";
        tagsEl.innerHTML = tags.map(function (t) { return '<span class="tag-pill">' + esc(t) + '</span>'; }).join("");
      } else tagsWrap.style.display = "none";
    }

    var repoLink = document.getElementById("aside-repo-link");
    var repoLabel = document.getElementById("aside-repo-label");
    if (repoLink) repoLink.href = skill.repoUrl || "#";
    if (repoLabel) repoLabel.textContent = skill.repo || "";
    var detailsLink = document.getElementById("aside-details-link");
    if (detailsLink) detailsLink.href = skill.detailsUrl || "#";
    var zipLink = document.getElementById("aside-zip-link");
    if (zipLink && skill.skillZipUrl) {
      zipLink.href = skill.skillZipUrl;
      zipLink.setAttribute("download", (skill.name || "skill").replace(/[^a-zA-Z0-9-_]/g, "") + ".zip");
    }

    var files = skill.files || [];
    var filesWrap = document.getElementById("aside-files-wrap");
    var filesList = document.getElementById("aside-files");
    if (filesWrap && filesList) {
      if (files.length) {
        filesWrap.style.display = "";
        filesList.innerHTML = files.map(function (f) {
          return '<li class="file-item"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>' + esc(f) + '</li>';
        }).join("");
      } else filesWrap.style.display = "none";
    }

    var cats = skill.categories || [];
    var catsWrap = document.getElementById("aside-cats-wrap");
    var catsEl = document.getElementById("aside-cats");
    if (catsWrap && catsEl && cats.length > 1) {
      catsWrap.style.display = "";
      catsEl.innerHTML = cats.map(function (c) {
        return '<a href="/' + currentLang + '/" class="aside-cat-link">' + esc(c) + '</a>';
      }).join("");
    } else if (catsWrap) catsWrap.style.display = "none";

    var langEn = "/en/skill/" + skill.id;
    var langZh = "/zh/skill/" + skill.id;
    document.querySelectorAll(".lang-link-en, .lang-dropdown-en").forEach(function (a) { a.href = langEn; a.classList.toggle("active", currentLang === "en"); });
    document.querySelectorAll(".lang-link-zh, .lang-dropdown-zh").forEach(function (a) { a.href = langZh; a.classList.toggle("active", currentLang === "zh"); });

    var ldJson = {
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      name: skill.name,
      description: skill.description,
      codeRepository: skill.repoUrl,
      author: { "@type": "Person", name: skill.author },
      programmingLanguage: "Markdown"
    };
    var existing = document.getElementById("skill-ldjson");
    if (existing) existing.remove();
    var script = document.createElement("script");
    script.type = "application/ld+json";
    script.id = "skill-ldjson";
    script.textContent = JSON.stringify(ldJson);
    document.body.appendChild(script);
  }

  if (!window.__skillStore) {
    showNotFound();
    return;
  }
  window.__skillStore.load(cdnBaseUrl).then(function () {
    var skill = window.__skillStore.getSkillById(skillId);
    if (!skill) {
      showNotFound();
      return;
    }
    showContent();
    renderSkill(skill);

    var tabs = document.querySelectorAll(".install-tab");
    var panels = document.querySelectorAll(".install-body[data-panel]");
    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        var tool = tab.dataset.tool;
        tabs.forEach(function (t) {
          t.classList.toggle("active", t.dataset.tool === tool);
          t.setAttribute("aria-selected", t.dataset.tool === tool ? "true" : "false");
        });
        panels.forEach(function (p) {
          p.style.display = p.dataset.panel === tool ? "" : "none";
        });
      });
    });
    document.querySelectorAll(".copy-btn").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var cmd = btn.dataset.cmd;
        if (!cmd) return;
        navigator.clipboard.writeText(cmd).then(function () {
          var copyIcon = btn.querySelector(".copy-icon");
          var checkIcon = btn.querySelector(".check-icon");
          if (copyIcon && checkIcon) {
            copyIcon.style.display = "none";
            checkIcon.style.display = "block";
            setTimeout(function () {
              copyIcon.style.display = "block";
              checkIcon.style.display = "none";
            }, 1500);
          }
        });
      });
    });
    var dropdown = document.querySelector(".lang-dropdown");
    var langToggle = dropdown && dropdown.querySelector(".lang-dropdown-toggle");
    if (dropdown && langToggle) {
      langToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        dropdown.classList.toggle("open");
      });
      document.addEventListener("click", function () { dropdown.classList.remove("open"); });
    }
  }).catch(function (err) {
    console.error("skill-store load failed:", err);
    showNotFound();
  });
})();
</script>

